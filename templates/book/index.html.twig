{% extends 'base.html.twig' %}

{% block title %}Books - Community Library{% endblock %}

{% block body %}
    <h1>Our Collection ({{ books|length }} books)</h1>

    <div class="listing-layout">
        <aside class="listing-sidebar">
            <h2>Filter</h2>
            <form method="get">
                <input type="search" name="q" value="{{ criteria.q }}" placeholder="Title…">
                <input type="text"   name="author" value="{{ criteria.author }}" placeholder="Author…">
                <select name="genre">
                    <option value="">All genres</option>
                    {% for genre in genres %}
                        <option value="{{ genre.id }}" {{ criteria.genre == genre.id ? 'selected' }}>{{ genre.name }}</option>
                    {% endfor %}
                </select>
                <label>
                    <input type="checkbox" name="available" value="1" {{ criteria.available ? 'checked' }}>
                    Only available
                </label>
                <button>Search</button>
            </form>
        </aside>

        <section class="listing-main">

            {# ── Sort bar ── #}
            <div class="sort-bar">
                Sort by:

                {% set isActive = criteria.sort.value == 'title' %}
                {% set nextDir  = isActive and criteria.direction == 'asc' ? 'desc' : 'asc' %}
                <a href="{{ path('app_book_index', app.request.query.all|merge({sort: 'title', direction: nextDir})) }}">
                    Title{% if isActive %} {{ criteria.direction == 'asc' ? '↑' : '↓' }}{% endif %}
                </a>

                {% set isActive = criteria.sort.value == 'author' %}
                {% set nextDir  = isActive and criteria.direction == 'asc' ? 'desc' : 'asc' %}
                <a href="{{ path('app_book_index', app.request.query.all|merge({sort: 'author', direction: nextDir})) }}">
                    Author{% if isActive %} {{ criteria.direction == 'asc' ? '↑' : '↓' }}{% endif %}
                </a>

                {% set isActive = criteria.sort.value == 'publicationDate' %}
                {% set nextDir  = isActive and criteria.direction == 'asc' ? 'desc' : 'asc' %}
                <a href="{{ path('app_book_index', app.request.query.all|merge({sort: 'publicationDate', direction: nextDir})) }}">
                    Publication date{% if isActive %} {{ criteria.direction == 'asc' ? '↑' : '↓' }}{% endif %}
                </a>
            </div>

            {# ── Grille de livres ── #}
            <div class="book-grid">
                {% for book in books %}
                    <div class="book-card">
                        <h2>
                            <a href="{{ path('app_book_show', {id: book.id}) }}">
                                {{ book.title }}
                            </a>
                        </h2>

                        {% if book.authors is not empty %}
                            <p>
                                {% for author in book.authors %}
                                    {{ author.name }}{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </p>
                        {% endif %}

                        {% if book.publicationDate %}
                            <p>{{ book.publicationDate|date('Y') }}</p>
                        {% endif %}

                        {% if book.genres is not empty %}
                            <p>
                                {% for genre in book.genres %}
                                    <em>{{ genre.name }}</em>{% if not loop.last %}, {% endif %}
                                {% endfor %}
                            </p>
                        {% endif %}

                        {% if is_granted('book.edit_details', book) %}
                            <a href="{{ path('app_admin_book_edit', {id: book.id}) }}"
                               class="btn btn-outline-secondary">Edit</a>
                        {% endif %}
                    </div>
                {% else %}
                    <p>No books found.</p>
                {% endfor %}
            </div>
            {% if totalPages > 1 %}
                <nav class="pagination">

                    {# Prev #}
                    {% if page > 1 %}
                        <a href="{{ path('app_book_index', app.request.query.all|merge({page: page - 1})) }}">
                            ← Prev
                        </a>
                    {% else %}
                        <span class="disabled">← Prev</span>
                    {% endif %}

                    {# Page X of Y #}
                    <span>Page {{ page }} of {{ totalPages }}</span>

                    {# Next #}
                    {% if page < totalPages %}
                        <a href="{{ path('app_book_index', app.request.query.all|merge({page: page + 1})) }}">
                            Next →
                        </a>
                    {% else %}
                        <span class="disabled">Next →</span>
                    {% endif %}

                </nav>
            {% endif %}
        </section>
    </div>
{% endblock %}
