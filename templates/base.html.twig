<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Community Library{% endblock %}</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">
    {% block stylesheets %}{% endblock %}
    {% block javascripts %}{% endblock %}
    {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>
<body>
<div class="wrapper">
    <header>
        <nav>
            <a href="{{ path('app_main_index') }}">Home</a>
            <a href="{{ path('app_main_about') }}">About</a>
            <a href="{{ path('app_book_index') }}">Books</a>
            <a href="{{ path('app_author_index') }}">Authors</a>
            <a href="{{ path('app_main_contact') }}">Contact</a>
            <div class="user-menu">
                {% if app.user %}
                    <span class="user-email">{{ app.user.email }}</span>
                    <a href="{{ path('app_logout') }}">Logout</a>
                {% else %}
                    <a href="{{ path('app_login') }}">Login</a>
                    <a href="{{ path('app_register') }}">Register</a>
                {% endif %}
            </div>
        </nav>
    </header>
    <main>
        {# `body` matches Symfony's convention; `main` would be more semantic #}
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }}">{{ message }}</div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
    <footer>
        <p>&copy; 2025 Community Library</p>
    </footer>
</div>
</body>
</html>
